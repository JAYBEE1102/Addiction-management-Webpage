rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().isAdmin == true;
    }

    // User Profile Documents
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Prevent self-promotion or self-unsuspension on creation
      allow create: if isOwner(userId) && 
        request.resource.data.isAdmin == false && 
        request.resource.data.suspended == false;
      
      // Normal users cannot self-promote to admin or change their suspended status
      allow update: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.isAdmin == resource.data.isAdmin && 
        request.resource.data.suspended == resource.data.suspended
      );
      
      allow delete: if isAdmin();
    }

    // Journal Reflections
    match /journal/{journalId} {
      allow read, write: if isAuthenticated() && (
        (resource == null || resource.data.uid == request.auth.uid) &&
        (request.resource == null || request.resource.data.uid == request.auth.uid)
      );
    }

    // Peer Support Feed Posts
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // Confidential Support & Booking Tickets
    match /tickets/{ticketId} {
      allow read, write: if isAuthenticated() && (
        (resource == null || resource.data.uid == request.auth.uid || isAdmin()) &&
        (request.resource == null || request.resource.data.uid == request.auth.uid || isAdmin())
      );
    }

    // Abuse Reports Collection
    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // Educational Resources FAQs
    match /faqs/{faqId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Educational Videos
    match /videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
